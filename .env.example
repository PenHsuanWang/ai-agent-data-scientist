# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# ANTHROPIC_BASE_URL=https://your-corporate-gateway/

# ── Model ────────────────────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=8192
MAX_RETRIES=2

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false

# ── Data directories ─────────────────────────────────────────────────────────
DATA_DIR=data
DOMAIN_DOCS_DIR=data/domain_docs
DATASETS_DIR=data/datasets

# ── Code execution ───────────────────────────────────────────────────────────
# Options: subprocess | jupyter | anthropic
CODE_EXECUTION_BACKEND=subprocess
CODE_EXECUTION_TIMEOUT=30
ENABLE_JUPYTER_BRIDGE=false

# ── ReAct loop ───────────────────────────────────────────────────────────────
MAX_REACT_ITERATIONS=20

# ── Output directories ───────────────────────────────────────────────────────
FIGURES_DIR=outputs/figures
NOTEBOOKS_DIR=outputs/notebooks
